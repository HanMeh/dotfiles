layout {
    // 1. Define a global template for every tab to keep the UI uniform
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="zellij:tab-bar"
        }
        children
        pane size=1 borderless=true {
            plugin location="zellij:status-bar"
        }
    }

    // TAB 1: Global File System Explorer
    tab name="📁 File Tree" {
        pane split_direction="vertical" {
            // Drop directly into Emacs Dired to manage files across directories
            pane name="Dired File Manager" size="30%" command="emacsclient" {
                args "-nw" "-e" "(dired \".\")"
            }
            // A standard shell workspace right next to your files
            pane name="Project Shell" size="70%"
        }
    }

    // TAB 2: Core Development Split
    tab name="💻 Core Code" focus=true {
        pane split_direction="vertical" {
            // Primary text buffer (takes up most of the space)
            pane name="Main Buffer" size="65%" command="emacsclient" focus=true {
                args "-nw" "-a" ""
            }
            // Secondary side-buffer for reference files or documentation
            pane name="Ref/Docs Buffer" size="35%" command="emacsclient" {
                args "-nw" "-a" ""
            }
        }
    }

    // TAB 3: Testing & Debugging Environment
    tab name="🧪 Tests" {
        pane split_direction="horizontal" {
            // Emacs workspace pinned specifically to test files
            pane name="Test Files Buffer" size="60%" command="emacsclient" {
                args "-nw" "-a" ""
            }
            // Live test runner or terminal compiler output pane below
            pane name="Test Runner Shell" size="40%"
        }
    }
}

// 2. Automatically engage Locked Mode at boot to stop keybinding hijacking
mode "Locked"
